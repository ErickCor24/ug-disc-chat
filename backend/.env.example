# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env

JWT_SECRET_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Modo SSL de asyncpg. Los Postgres gestionados (Neon, Supabase, Render)
# exigen "require". Un Postgres local no negocia SSL: usar "disable".
DB_SSL=require

ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:8050"]
DEBUG=True
